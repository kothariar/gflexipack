---
layout: layouts/base.njk
pagination:
  data: industries
  size: 1
  alias: sector
permalink: "/industries/{{ sector.slug }}/"
eleventyComputed:
  title: "{{ sector.name }} Packaging | G Flexipack · Bharuch, India"
  description: "{{ sector.metaDescription }}"
  pageImage: "/assets/images/{{ sector.image }}.png"
---

  <section class="pp-hero">
    <div>
      <p class="pp-crumbs">
        <a href="/">Home</a><span>/</span><a href="/industries/">Industries</a><span>/</span>{{ sector.name }}
      </p>
      <h1>{{ sector.name }} <em>packaging.</em></h1>
      <p class="pp-intro">{{ sector.intro }}</p>
      <div class="pp-hero-ctas">
        <a class="cta cta-primary" href="/#inquiry">Get a quote <span class="arrow" aria-hidden="true">→</span></a>
        <a class="cta cta-ghost" href="/industries/">All industries <span class="arrow" aria-hidden="true">→</span></a>
      </div>
    </div>
    <div class="pp-photo" style="--cream-2:{{ sector.accent }};" data-reveal>
      <img src="/assets/images/{{ sector.image }}.png" alt="{{ sector.name }} packaging by G Flexipack" />
    </div>
  </section>

  <!-- APPLICATIONS -->
  <section class="sec">
    <div class="sec-head" data-reveal>
      <p class="sec-eyebrow">What we pack</p>
      <h2 class="sec-title">Built for the <em>{{ sector.short | lower }} shelf.</em></h2>
    </div>
    <div class="pp-apps" data-reveal>
      {% for a in sector.applications %}<span class="pp-app">{{ a }}</span>
      {% endfor %}
    </div>
    <p style="text-align:center; max-width:640px; margin:34px auto 0; color:var(--ink-soft); font-size:15px; line-height:1.65;"><strong style="color:var(--ink); font-weight:500;">Typical build:</strong> {{ sector.build }}</p>
  </section>

  <!-- RECOMMENDED FORMATS -->
  <section class="pp-dark">
    <div class="sec">
      <div class="sec-head" data-reveal>
        <p class="sec-eyebrow">Recommended formats</p>
        <h2 class="sec-title">Formats that suit <em>{{ sector.short | lower }}.</em></h2>
      </div>
      <div class="pp-related" data-reveal>
        {% for slug in sector.formats %}{% for p in products %}{% if p.slug == slug %}<a href="/products/{{ p.slug }}/" style="color:var(--cream); border-color:rgba(244,239,231,0.32);">{{ p.name }} →</a>{% endif %}{% endfor %}{% endfor %}
      </div>
    </div>
  </section>

  <!-- CTA BAND -->
  <section class="pp-band">
    <div class="sec">
      <h2 data-reveal>Packaging for your <em>{{ sector.short | lower }} brand.</em></h2>
      <p data-reveal>Share your product, format and quantity — structure recommendation within {{ site.quoteTurnaround }}, quote in 48 hours.</p>
      <a class="cta cta-light" href="/#inquiry" data-reveal>Get a quote <span class="arrow" aria-hidden="true">→</span></a>
    </div>
  </section>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "{{ site.url }}/" },
      { "@type": "ListItem", "position": 2, "name": "Industries", "item": "{{ site.url }}/industries/" },
      { "@type": "ListItem", "position": 3, "name": "{{ sector.name }}", "item": "{{ site.url }}/industries/{{ sector.slug }}/" }
    ]
  }
  </script>
