  <!-- ============ INQUIRY ============ -->
  <section class="inquiry" id="inquiry">
    <div class="sec">
      <div class="sec-head" data-reveal>
        <p class="sec-eyebrow">Inquiry</p>
        <h2 class="sec-title">Tell us what <em>you pack.</em></h2>
        <p class="sec-lead">Share your requirements — we come back with a structure recommendation within {{ site.quoteTurnaround }} and a detailed quote within two business days.</p>
      </div>
      <div class="inq-grid">
        <!-- Wire the action to Formspree (or backend) before go-live -->
        <form class="inq-form" action="https://formspree.io/f/your-form-id" method="POST" data-reveal>
          <div class="fg"><label for="q-name">Name</label><input id="q-name" name="name" type="text" placeholder="Jane Smith" required /></div>
          <div class="fg"><label for="q-company">Company</label><input id="q-company" name="company" type="text" placeholder="Your brand" /></div>
          <div class="fg"><label for="q-email">Business email</label><input id="q-email" name="email" type="email" placeholder="jane@yourbrand.com" required /></div>
          <div class="fg"><label for="q-phone">Phone / WhatsApp</label><input id="q-phone" name="phone" type="tel" placeholder="+91 …" /></div>
          <div class="fg"><label for="q-product">Product type</label>
            <select id="q-product" name="product">
              <option>Select format…</option>
              {% for p in products %}<option>{{ p.name }}</option>
              {% endfor %}<option>Other / Multiple</option>
            </select>
          </div>
          <div class="fg"><label for="q-qty">Quantity</label><input id="q-qty" name="quantity" type="text" placeholder="e.g. 25,000 units" /></div>
          <div class="fg fg-full"><label for="q-msg">Requirements</label><textarea id="q-msg" name="requirements" placeholder="Size, barrier needs, artwork status, target ship-by date…"></textarea></div>
          <button class="cta cta-light inq-submit" style="justify-content:center" type="submit">Send enquiry <span class="arrow" aria-hidden="true">→</span></button>
        </form>
        <div class="inq-side" data-reveal>
          <h3>Prefer to talk <em>directly?</em></h3>
          <ul class="inq-rows">
            <li><span class="k">Email</span><span><a href="mailto:{{ site.email }}">{{ site.email }}</a></span></li>
            <li><span class="k">Phone</span><span><a href="tel:{{ site.phonePrimaryE164 }}">{{ site.phones[0] }}</a><br /><a href="tel:{{ site.phoneSecondaryE164 }}">{{ site.phones[1] }}</a></span></li>
            <li><span class="k">Hours</span><span>{{ site.hours }}</span></li>
            <li><span class="k">Plant</span><span>{{ site.address.street }},<br />{{ site.address.city }}, {{ site.address.region }} {{ site.address.postalCode }}, {{ site.address.country }}</span></li>
            <li><span class="k">Terms</span><span>MOQ {{ site.moq }} · {{ site.payment }} payment · {{ site.leadTime }} lead · {{ site.incoterms }}</span></li>
          </ul>
          <div class="inq-map">
            <iframe
              title="G Flexipack plant location — GIDC Phase-1, Bharuch"
              src="https://www.google.com/maps?q=GIDC%20Phase-1%20Narmada%20Nagar%20Bharuch%20Gujarat%20392015&output=embed"
              width="100%" height="220" style="border:0; border-radius:12px; margin-top:22px;"
              loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>
