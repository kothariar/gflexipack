  <!-- ============ THE LAB (eight tests) ============ -->
  <section class="lab" id="lab">
    <div class="sec" style="padding-bottom:0;">
      <div class="sec-head" data-reveal>
        <p class="sec-eyebrow">The lab</p>
        <h2 class="sec-title">Eight tests. <em>Every batch.</em></h2>
        <p class="sec-lead">Raw material inspected on arrival, colour verified before print, tested in-line at every stage, documented at dispatch.</p>
      </div>
    </div>

    <div class="lab-grid">
      <ol class="test-sheet" data-reveal>
        <li class="test-row"><span class="test-no">01</span><span class="test-name">GSM</span><span class="test-proof">film weight is consistent, roll to roll</span></li>
        <li class="test-row"><span class="test-no">02</span><span class="test-name">COF</span><span class="test-proof">runs smoothly on high-speed filling lines</span></li>
        <li class="test-row"><span class="test-no">03</span><span class="test-name">Bond strength</span><span class="test-proof">laminate layers never separate</span></li>
        <li class="test-row"><span class="test-no">04</span><span class="test-name">Puncture resistance</span><span class="test-proof">survives transit, stacking and handling</span></li>
        <li class="test-row"><span class="test-no">05</span><span class="test-name">Burst strength</span><span class="test-proof">seals hold under internal pressure</span></li>
        <li class="test-row"><span class="test-no">06</span><span class="test-name">Scrub test</span><span class="test-proof">print doesn't rub off in the supply chain</span></li>
        <li class="test-row"><span class="test-no">07</span><span class="test-name">Heat seal strength</span><span class="test-proof">every seam holds, every time</span></li>
        <li class="test-row"><span class="test-no">08</span><span class="test-name">Tear strength</span><span class="test-proof">opens where it should — nowhere else</span></li>
      </ol>

      <div class="lab-side" data-reveal>
        <blockquote class="quality-quote">&ldquo;Quality <em>without</em> compromise.&rdquo;</blockquote>
        <p class="quality-src">Quality policy · tested to ASTM standards</p>
        <div class="lab-photos">
          <figure class="lab-photo" style="margin:0;">
            <img src="/assets/images/heat.png" alt="Heat seal tester" loading="lazy" />
            <figcaption>Heat seal tester</figcaption>
          </figure>
          <figure class="lab-photo" style="margin:0;">
            <img src="/assets/images/punture.png" alt="Puncture and tensile tester" loading="lazy" />
            <figcaption>Puncture tester</figcaption>
          </figure>
          <figure class="lab-photo" style="margin:0;">
            <img src="/assets/images/cutter.png" alt="Sample cutter" loading="lazy" />
            <figcaption>Sample cutter</figcaption>
          </figure>
        </div>
        <div class="cert-line">
          <span class="cert-chip">ISO 9001:2015</span>
          <span class="cert-chip">ASTM Standard QC</span>
          <span class="cert-chip">100% Recyclable Options</span>
        </div>
      </div>
    </div>
  </section>
