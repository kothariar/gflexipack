  <!-- HERO / INTRO -->
  <section class="sec" style="padding-bottom:20px;">
    <div class="sec-head" data-reveal>
      <p class="pp-crumbs" style="text-align:center;"><a href="/">Home</a><span>/</span>FAQs</p>
      <p class="sec-eyebrow">FAQs</p>
      <h1 class="sec-title" style="margin:0 auto 20px;">Common <em>questions.</em></h1>
      <p class="pp-intro" style="margin:0 auto;">Answers to what most brands ask before their first order. Can't find yours — send it to us directly.</p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="sec" style="padding-top:0;">
    <div class="faq" data-reveal>
      {% for f in faqs %}<details{% if loop.first %} open{% endif %}>
        <summary>{{ f.q }}</summary>
        <p>{{ f.a }}{% if f.link %} <a href="{{ f.link.href }}" style="color:var(--accent); text-decoration:underline;">{{ f.link.text }}</a>{% endif %}</p>
      </details>
      {% endfor %}
    </div>
  </section>

  <!-- CTA BAND -->
  <section class="pp-band">
    <div class="sec">
      <h2 data-reveal>Still have <em>a question?</em></h2>
      <p data-reveal>Send it to us directly — structure recommendation within 24 hours, quote in 48.</p>
      <a class="cta cta-light" href="/#inquiry" data-reveal>Get a quote <span class="arrow" aria-hidden="true">→</span></a>
    </div>
  </section>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {% for f in faqs %}{
        "@type": "Question",
        "name": "{{ f.q }}",
        "acceptedAnswer": { "@type": "Answer", "text": "{{ f.a }}" }
      }{% if not loop.last %},{% endif %}
      {% endfor %}
    ]
  }
  </script>
