{% set faqs = [
  { q: "What's the minimum order quantity?", a: "Reach out with your product and target quantity — we'll confirm what works for a trial or first order." },
  { q: "How long does production take?", a: "3–5 weeks from artwork approval to dispatch, depending on structure and print complexity. We confirm a firm date before production starts." },
  { q: "How fast can I get a quote?", a: "Structure recommendation within 24 hours of your brief, full quote within 48 hours." },
  { q: "Can you recommend a structure if I'm not sure what I need?", a: "Yes — send your product, target shelf life and rough budget, and we'll recommend a laminate structure within 24 hours." },
  { q: "What pouch formats do you make?", a: "Fourteen formats, including stand-up, zipper, gusseted, spout, retort, vacuum, centre seal, 3-side seal, 4-side seal, patch handle, poly film rolls, breathing pouches and shape pouches.", link: { href: "/products/", text: "See all formats →" } },
  { q: "What industries do you serve?", a: "Food & grocery, beverages, pharmaceuticals, personal care, agrochemical, household and industrial.", link: { href: "/industries/", text: "See all industries →" } },
