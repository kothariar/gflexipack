---
layout: layouts/base.njk
pagination:
  data: products
  size: 1
  alias: product
permalink: "/products/{{ product.slug }}/"
ogType: "product"
eleventyComputed:
  title: "{{ product.name }} Manufacturer | G Flexipack · Bharuch, India"
  description: "{{ product.metaDescription }}"
  pageImage: "/assets/images/{{ product.image }}.png"
---
{% set defaultStructures = ["PET / METPET / PE", "MATTE BOPP / METPET / PE", "PET / PE", "BOPA / PE", "PET / Alu / PE", "PET / Alu / BOPA / PE", "PE / PE", "Alox PET / PE"] %}
{% set lamTags = {
  "PET / METPET / PE": "High barrier",
  "MATTE BOPP / METPET / PE": "High · matte",
  "PET / PE": "Everyday",
  "BOPA / PE": "Puncture-resist",
  "PET / Alu / PE": "Ultra barrier",
  "PET / Alu / BOPA / PE": "Max barrier",
  "PE / PE": "Economical",
  "Alox PET / PE": "Clear barrier",
  "MDOPE / PE": "Recyclable",
  "BOPA / PE (nylon-PE)": "Puncture-resist",
  "High-clarity PA / PE": "High clarity",
  "PET / Alu / CPP": "Retort-grade",
  "PET / BOPA / Alu / CPP": "Retort · tough",
  "PET / Nylon / CPP (transparent retort)": "Transparent"
} %}
{% if product.structures %}
  {% set structures = product.structures %}
{% else %}
  {% set structures = defaultStructures.concat(["MDOPE / PE"]) %}
{% endif %}
{% set builtins = product.builtin or product.features %}
{# arc offsets — rows bow away from the product's widest point #}
{% set arcMid = { "3": [26, 34, 26], "4": [20, 33, 33, 20], "5": [16, 28, 34, 28, 16], "9": [8, 19, 28, 35, 38, 35, 28, 19, 8] } %}
{% set arcRise = { "3": [10, 20, 28], "4": [8, 15, 22, 27], "5": [8, 16, 22, 26, 28] } %}
{% set arcFall = { "3": [22, 14, 6], "4": [24, 18, 11, 5], "5": [26, 21, 15, 9, 4] } %}
{% set nStruct = (structures | length) ~ "" %}
{% set nPacks = (product.applications | length) ~ "" %}
{% set nBuilt = (builtins | length) ~ "" %}
{% set arcL = arcMid[nStruct] or arcRise[nStruct] %}
{% set arcPacks = arcRise[nPacks] %}
{% set arcBuilt = arcFall[nBuilt] %}
{% set girth = product.girth or 1 %}
{% set scale = product.scale or 1 %}

  <!-- SHELF SHEET — everything at a glance -->
  <section class="pp-sheet">
    <div class="pp-floor"></div>
    <div class="pp-wglow" style="--pglow:{{ product.tbg }}"></div>
    <p class="pp-crumbs pp-crumbs--sheet">
      <a href="/">Home</a><span>/</span><a href="/products/">Products</a><span>/</span>{{ product.name }}
    </p>

    <div class="pp-sgrid" style="--pgirth:{{ girth }};--pscale:{{ scale }}">
      <!-- LEFT — structures -->
      <div class="pp-sflank pp-sfl-l">
        <div class="pp-sclu">
          <div class="pp-sclu-h"><span>Structure options</span></div>
          <ul>
            {% for s in structures %}
            <li{% if s == "MDOPE / PE" %} class="rec"{% endif %} style="--arc:{{ ((arcL[loop.index0] or 0) * girth) | round }}px"><b>{{ s }}</b>{% if lamTags[s] %}<span class="pp-st">{{ lamTags[s] }}</span>{% endif %}</li>
            {% endfor %}
          </ul>
        </div>
      </div>

      <!-- CENTRE — the product on the shelf -->
      <div class="pp-smid">
        <h1>{{ product.name }}<em>.</em></h1>
        <p class="pp-slede">{{ product.lede }}</p>
        <div class="pp-pod">
          {% if product.cut %}
          <img src="/assets/images/{{ product.cut }}.png" alt="{{ product.name }} — custom printed by G Flexipack" />
          {% else %}
          <img class="is-card" src="/assets/images/{{ product.image }}.png" alt="{{ product.name }} — custom printed by G Flexipack" />
          {% endif %}
        </div>
        <div class="pp-underlip">
          <div class="pp-sctas">
            <a class="cta cta-light" href="/#inquiry">Get a quote <span class="arrow" aria-hidden="true">→</span></a>
            <a class="cta pp-soline" href="/products/">All formats <span class="arrow" aria-hidden="true">→</span></a>
          </div>
        </div>
      </div>

      <!-- RIGHT — markets + built-in -->
      <div class="pp-sflank pp-sfl-r">
        <div class="pp-sclu">
          <div class="pp-sclu-h"><span>Commonly packs</span></div>
          <ul>
            {% for a in product.applications %}
            <li style="--arc:{{ ((arcPacks[loop.index0] or 0) * girth) | round }}px"><b>{{ a }}</b></li>
            {% endfor %}
          </ul>
        </div>
        <div class="pp-sclu">
          <div class="pp-sclu-h" style="--arc:{{ ((arcBuilt[0] + 3) * girth) | round }}px"><span>Built in</span></div>
          <ul>
            {% for f in builtins %}
            <li style="--arc:{{ ((arcBuilt[loop.index0] or 0) * girth) | round }}px"><b>{{ f.t }}</b>{% if f.opt %}<span class="pp-sopt">Optional</span>{% elif f.tag %}<span class="pp-st">{{ f.tag }}</span>{% endif %}</li>
            {% endfor %}
          </ul>
          {% if product.finishes %}
          <p class="pp-sfin" style="--arc:2px"><b>Finishes</b> — {% for fi in product.finishes %}{{ fi }}{% if not loop.last %}<i>·</i>{% endif %}{% endfor %}</p>
          {% endif %}
        </div>
      </div>
    </div>
  </section>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Product",
        "name": "{{ product.name }}",
        "image": "{{ site.url }}/assets/images/{{ product.image }}.png",
        "description": "{{ product.metaDescription }}",
        "category": "Flexible packaging",
        "url": "{{ site.url }}/products/{{ product.slug }}/",
        "brand": { "@type": "Brand", "name": "G Flexipack" },
        "manufacturer": { "@id": "{{ site.url }}/#organization" }
      },
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "{{ site.url }}/" },
          { "@type": "ListItem", "position": 2, "name": "Products", "item": "{{ site.url }}/products/" },
          { "@type": "ListItem", "position": 3, "name": "{{ product.name }}", "item": "{{ site.url }}/products/{{ product.slug }}/" }
        ]
      }
    ]
  }
  </script>
