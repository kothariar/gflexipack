    /* vertical marquee — two columns, opposite directions */
    .hh-marquee {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
      height: 660px;
      position: relative;
      --hh-tile-h: 200px;
      --hh-tile-gap: 14px;
