    .hh-col::after { bottom: 0; background: linear-gradient(to top, var(--cream), rgba(244,239,231,0)); }
    .hh-track {
      display: flex;
      flex-direction: column;
      gap: var(--hh-tile-gap);
      animation-timing-function: linear;
      animation-iteration-count: infinite;
